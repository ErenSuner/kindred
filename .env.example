# Copy to .env and fill in. These are EXPO_PUBLIC_ so they are embedded in the
# client bundle by design (the Supabase anon key is safe to ship; row-level
# security is what protects data). Never put service-role keys here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry crash reporting (Phase B1). Leave blank to disable in dev.
EXPO_PUBLIC_SENTRY_DSN=

# --- EAS builds ---
# Local .env is NOT read by EAS Build. Register the same EXPO_PUBLIC_* values as
# EAS environment variables so cloud builds pick them up:
#   npx eas env:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..." --environment production --environment preview --visibility plaintext
#   npx eas env:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..." --environment production --environment preview --visibility plaintext
